-- create schema
CREATE TABLE census (
    census_id    INTEGER PRIMARY KEY,
    state        TEXT NOT NULL,
    year         INTEGER NOT NULL,
    population   INTEGER NOT NULL,
    poverty_rate REAL
);

CREATE TABLE outbreaks (
    outbreak_id       INTEGER PRIMARY KEY,
    year              INTEGER NOT NULL,
    month             INTEGER,
    state             TEXT NOT NULL,
    primary_mode      TEXT,
    etiology          TEXT,
    etiology_status   TEXT,
    etiology_category TEXT,
    setting_category  TEXT,
    ifsac_category    TEXT,
    illnesses         INTEGER,
    hospitalizations  INTEGER,
    deaths            INTEGER
);
---------------------------------------------------------------------------------------------------------------------

-- Copy in data to tables
COPY census (census_id, state, year, population, poverty_rate)
FROM 'data/processed/census.csv'
DELIMITER ',' CSV HEADER;

COPY outbreaks (outbreak_id, year, month, state, primary_mode, etiology,
                etiology_status, ifsac_category, illnesses, hospitalizations,
                deaths, etiology_category, setting_category)
FROM 'data/processed/outbreaks.csv'
DELIMITER ',' CSV HEADER;

